def extract_pdf_text(pdf_path):
	try:
		p = Popen(['pdftotext', pdf_path, '-'], stdout=PIPE, stderr=PIPE)
		stdout, _ = p.communicate()
		if p.returncode == 0:
			return stdout.decode('utf-8', errors='replace')
	except Exception:
		pass
	return ''

def suggest_filename(pdf_path):
	if not OllamaModel:
		return None
	text = extract_pdf_text(pdf_path).strip()
	if not text:
		print('(pdftotext returned no text — is poppler installed?)')
		return None
	prompt = (
		'Output format: exactly 6-10 lowercase words separated by underscores. '
		'No sentences, no explanation, no punctuation. Only the words.\n'
		'Example output: telekom_rechnung_januar_2026_mobilfunk_vertrag\n\n'
		'Rules:\n'
		'- First word: name of the organization or company the document is from\n'
		'- If it is a letter: use the subject line (Betreff/Re/Betrifft) for the remaining words\n'
		'- Use specific terms (names, amounts, topics), not generic words like "brief" or "dokument"\n'
		'- Use the language of the document\n\n'
		'Document text:\n'
		+ text[:1000] + '\n\n'
		'Output (6-10 words, underscores only):'
	)
	payload = json.dumps({'model': OllamaModel, 'prompt': prompt, 'stream': False}).encode()
	try:
		req = urllib.request.Request(
			'http://localhost:11434/api/generate',
			data=payload,
			headers={'Content-Type': 'application/json'}
		)
		with urllib.request.urlopen(req, timeout=120) as resp:
			raw = json.loads(resp.read()).get('response', '').strip()
			keywords = re.sub(r'[^a-z0-9äöüß]', '_', raw.lower())
			keywords = re.sub(r'_+', '_', keywords).strip('_')
			return keywords if keywords else None
	except Exception as e:
		print('(ollama not reachable: ' + str(e) + ')')
		return None

try:
	from prompt_toolkit import prompt as pt_prompt
	from prompt_toolkit.completion import Completer, Completion
	from prompt_toolkit.validation import Validator, ValidationError as PTValidationError

	class _FileNameCompleter(Completer):
		def get_completions(self, document, complete_event):
			text = document.text.lower()
			if not text:
				return
			for f in sorted(os.listdir(os.getcwd())):
				if not f.lower().endswith('.pdf'):
					continue
				name = f[:-4]
				if text in name.lower() and name.lower() != text:
					yield Completion(name, start_position=-len(document.text))

	class _FileExistsValidator(Validator):
		def validate(self, document):
			text = document.text.strip()
			if not text:
				return
			if os.path.exists(os.path.join(os.getcwd(), text + '.pdf')):
				raise PTValidationError(
					message='"' + text + '.pdf" already exists — modify the name',
					cursor_position=len(text)
				)

	_has_prompt_toolkit = True
except ImportError:
	_has_prompt_toolkit = False


def prompt_filename():
	"""Interactive filename prompt before scanning. Returns chosen name (no extension)."""
	try:
		if _has_prompt_toolkit:
			name = pt_prompt(
				'Output filename (without .pdf): ',
				completer=_FileNameCompleter(),
				validator=_FileExistsValidator(),
				validate_while_typing=True,
			).strip()
		else:
			name = input('Output filename (without .pdf): ').strip()
	except KeyboardInterrupt:
		sys.exit(1)
	return name if name else datetime.now().strftime('%Y-%m-%d')


def llm_rename(current_path):
	"""Post-OCR: ask LLM for a suggestion, then offer a rename prompt."""
	print('Asking LLM for filename suggestion...')
	suggestion = suggest_filename(current_path)
	date_prefix = datetime.now().strftime('%Y-%m-%d')
	prefill = (date_prefix + '_' + suggestion) if suggestion else date_prefix + '_'
	if suggestion:
		print('LLM suggestion: ' + prefill)
	readline.set_startup_hook(lambda: readline.insert_text(prefill))
	try:
		new_name = input('Rename (without .pdf, Enter to confirm, Ctrl-C to keep): ').strip()
	except KeyboardInterrupt:
		print('\nKeeping current filename.')
		return current_path
	finally:
		readline.set_startup_hook()
	if not new_name:
		return current_path
	new_path = os.path.join(os.path.dirname(current_path), new_name + '.pdf')
	if not os.path.exists(new_path):
		os.rename(current_path, new_path)
		return new_path
	print('File already exists, keeping current name.')
	return current_path

def find_image_viewer():
	for viewer in ['feh', 'display', 'eog', 'xdg-open']:
		if shutil.which(viewer):
			return viewer
	return None

def show_image(filepath):
	viewer = find_image_viewer()
	if viewer is None:
		return None
	if viewer == 'feh':
		return Popen(['feh', '--auto-zoom', '--scale-down', filepath])
	if viewer == 'display':
		return Popen(['display', '-resize', '1200x1600>', filepath])
	return Popen([viewer, filepath])

def close_viewer(proc):
	if proc is None:
		return
	proc.terminate()
	try:
		proc.wait(timeout=2)
	except Exception:
		proc.kill()

