def print_output_size(filepath):
	try:
		size = os.path.getsize(filepath)
		if size >= 1024 * 1024:
			print('Output: ' + filepath + ' (%.1f MB)' % (size / 1024 / 1024))
		else:
			print('Output: ' + filepath + ' (%.0f KB)' % (size / 1024))
	except OSError:
		pass

# Remove garbage files, if existing
def CleanUp(filename = ''):

	if (filename == ''):
		filename = TempFile

	for filename in glob.glob(filename + '*.*') :
		os.remove(filename)


# Set Verbosity string
def verbosity():
	if (verbose == False):
		return '>/dev/null 2>&1'
	else:
		return ''


# Returns True in case the output file already exists.
def OutputFileExists(SaveFile, mode):
	if ( (os.path.exists(SaveFile + '.'+SaveFormatOCR+'') == True and ( mode == 'scanocr' or mode == 'ocr' ) )
	or (os.path.exists(SaveFile + '.' + SaveFormatScanOnly) == True and mode == 'scan') ):
		return True
	else:
		return False


# Main program
def main():
	args = parser.parse_args()

	if args.output is None:
		args.output = 'scan_' + datetime.now().strftime('%Y%m%d_%H%M%S')

	# Strip any file extension the user may have added (e.g. Foo.pdf -> Foo)
	args.output = os.path.splitext(args.output)[0]

	# Mode switcher
	print('Current Mode: ', end='')
	if args.mode == 'scanocr':
		print('Scan and OCR')
	elif args.mode == 'scan':
		print('Scan only')
	elif args.mode == 'ocr':
		print('OCR only')
		print('Not yet implemented.')
		sys.exit(0) # For now
	else:
		sys.exit('No valid mode given. Please choose one of: scanocr, scan, ocr')

	print('Device: %s | %sdpi | %sx%smm | %s' % (
		device, args.resolution, args.width, args.height,
		AdditionalScanOptions.strip()))

	global TempFile, SaveFile, verbose, _temp_prefix

	# Process verbose-switch ...
	verbose = args.verbose

	# Path and name (random string) of temporary file without extension
	RandomString = ''.join(random.choice(string.ascii_uppercase + string.digits) for x in range(6))
	TempFile = '/tmp/scanner_'+ RandomString + args.output
	SaveFile = os.getcwd() + '/' + args.output
	_temp_prefix = '/tmp/scanner_' + RandomString + args.output

	# check if output file exists
	if OutputFileExists(SaveFile, args.mode) == True:
		sys.exit('Output file exists.')

	# Create multi-page OCR'ed PDF
	if  (args.multi == True):
		page_num = 0
		done = False
		while not done:
			page_num += 1

			# Inner loop: rescan this page if needed
			while True:
				TempFile = '/tmp/scanner_'+ RandomString + args.output + '_' + str(page_num)
				print('--- Page ' + str(page_num) + ' ---')

				if not scan(args.resolution, args.width, args.height, args.progress):
					for f in glob.glob(TempFile + '*'):
						os.remove(f)
					answer = input('Insert document and press Enter to retry (q = abort): ').strip().lower()
					if answer == 'q':
						done = True
						page_num -= 1
						break
					continue  # retry same page

				if args.color:
					preview_file = TempFile + '.' + TempFormat
				else:
					optimizeImage('')
					preview_file = TempFile + '.bw.' + TempFormat

				viewer_proc = show_image(preview_file)
				while True:
					answer = input('Page ok? [Enter = next page, n = rescan, r = rotate 90°, q = done]: ').strip().lower()
					if answer == 'r':
						close_viewer(viewer_proc)
						call(['magick', 'mogrify', '-rotate', '90', preview_file])
						viewer_proc = show_image(preview_file)
					else:
						break
				close_viewer(viewer_proc)

				if answer == 'n':
					# Delete temp files for this page and rescan
					for f in glob.glob(TempFile + '*'):
						os.remove(f)
					page_num -= 1  # will be incremented again at top of outer loop
					break
				elif answer == 'q':
					done = True
					break
				else:
					break  # keep page, continue to next

		print('Scanned ' + str(page_num) + ' page(s) in total.')

		# ocr or no ocr
		page_glob = '/tmp/scanner_'+ RandomString + args.output
		if args.mode == 'scanocr':
			if args.color:
				call('magick '+page_glob+'_*.'+TempFormat+' '+TempFile+'.merged.pdf', shell=True)
			else:
				call('magick '+page_glob+'_*.bw.'+TempFormat+' '+TempFile+'.merged.pdf', shell=True)
			ocr(SaveFile, args.language)
		elif args.mode == 'scan':
			if args.color:
				call('magick '+page_glob+'_*.'+TempFormat+' '+SaveFile+'.'+SaveFormatScanOnly, shell=True)
			else:
				call('magick '+page_glob+'_*.bw.'+TempFormat+' '+SaveFile+'.'+SaveFormatScanOnly, shell=True)

		# Clean up temporary files
		CleanUp('/tmp/scanner_'+ RandomString + args.output)

		if args.mode == 'scanocr':
			print_output_size(SaveFile + '.' + SaveFormatOCR)
		elif args.mode == 'scan':
			print_output_size(SaveFile + '.' + SaveFormatScanOnly)

		sys.exit(0)

	# Normal operation if not in multipage-mode
	while True:
		if not scan(args.resolution, args.width, args.height, args.progress):
			for f in glob.glob(TempFile + '*'):
				os.remove(f)
			answer = input('Insert document and press Enter to retry (q = abort): ').strip().lower()
			if answer == 'q':
				sys.exit(1)
			continue

		if args.color:
			preview_file = TempFile + '.' + TempFormat
			blackwhite = ''
		else:
			optimizeImage('')
			preview_file = TempFile + '.bw.' + TempFormat
			blackwhite = '.bw'

		viewer_proc = show_image(preview_file)
		while True:
			answer = input('Page ok? [Enter = continue, n = rescan, r = rotate 90°, q = abort]: ').strip().lower()
			if answer == 'r':
				close_viewer(viewer_proc)
				call(['magick', 'mogrify', '-rotate', '90', preview_file])
				viewer_proc = show_image(preview_file)
			else:
				break
		close_viewer(viewer_proc)

		if answer == 'n':
			for f in glob.glob(TempFile + '*'):
				os.remove(f)
			continue
		elif answer == 'q':
			sys.exit(1)
		else:
			break

	# merge to pdf (after preview so rotations are included)
	if args.color:
		call('magick '+TempFile+'.'+TempFormat+' '+TempFile+'.merged.'+SaveFormatOCR+'', shell=True)
	else:
		call('magick '+TempFile+'.bw.'+TempFormat+' '+TempFile+'.merged.'+SaveFormatOCR+'', shell=True)

	# convert TempFormat to image-format
	if (args.mode == 'scan'):
		convertToImage(blackwhite)

	# ocr
	if (args.mode == 'scanocr'):
		ocr(SaveFile, args.language)

	CleanUp()

	if args.mode == 'scanocr':
		print_output_size(SaveFile + '.' + SaveFormatOCR)
	elif args.mode == 'scan':
		print_output_size(SaveFile + '.' + SaveFormatScanOnly)

	# End program
	sys.exit(0)


if __name__ == "__main__":
		main()
