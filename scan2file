	global SaveFormatScanOnly

	print('Convert: \t', end='')

	p = execute('magick ' +TempFile + bw + '.'+TempFormat+' '+SaveFile+'.'+SaveFormatScanOnly)

	if p[0] != 0:
		sys.exit ('Error converting '+TempFormat+' to ' + SaveFormatScanOnly + ': ' + p[1])
