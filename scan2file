_temp_prefix = None

def _cleanup_temp_files():
	if _temp_prefix is not None:
		for f in glob.glob(_temp_prefix + '*'):
			try:
				os.remove(f)
			except OSError:
				pass

atexit.register(_cleanup_temp_files)

def find_image_viewer():
	for viewer in ['feh', 'display', 'eog', 'xdg-open']:
		if shutil.which(viewer):
			return viewer
	return None

def show_image(filepath):
	viewer = find_image_viewer()
	if viewer is None:
		return None
	if viewer == 'feh':
		return Popen(['feh', '--auto-zoom', '--scale-down', filepath])
	if viewer == 'display':
		return Popen(['display', '-resize', '1200x1600>', filepath])
	return Popen([viewer, filepath])

def close_viewer(proc):
	if proc is None:
		return
	proc.terminate()
	try:
		proc.wait(timeout=2)
	except Exception:
		proc.kill()

